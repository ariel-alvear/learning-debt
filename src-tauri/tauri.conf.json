{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "learning-debt",
  "version": "0.1.0",
  "identifier": "com.learningdebt.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Learning Debt",
        "width": 420,
        "height": 360,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
